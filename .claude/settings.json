{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/eslint-fix.cjs",
            "timeout": 15,
            "statusMessage": "Running eslint --fix on frontend file..."
          }
        ]
      }
    ]
  }
}
